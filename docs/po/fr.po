msgstr "`pre-sync` / `post-sync`"

#: EXTENDING.md:39
msgid "before/after a `haw sync`"
msgstr "avant/après un `haw sync`"

#: EXTENDING.md:40
msgid "`pre-lock` / `post-lock`"
msgstr "`pre-lock` / `post-lock`"

#: EXTENDING.md:40
msgid "around lockfile (re)generation"
msgstr "autour de la (re)génération du lockfile"

#: EXTENDING.md:41
msgid "`post-switch`"
msgstr "`post-switch`"

#: EXTENDING.md:41
