msgstr "`6`"

#: learn/04-the-tui-cockpit.md:125
msgid "**governance** — plugins, SBOM, findings"
msgstr "**gouvernance** — plugins, SBOM, conclusions"

#: learn/04-the-tui-cockpit.md:125 CLI-DESIGN.md:124
msgid "`:governance`"
msgstr "`:governance`"

